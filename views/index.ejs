<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title>Document</title>
</head>
<body>
    <h1>This is an ejs file</h1>


  <%= gender %>

  <%# conditional statements in ejs, looping in ejs, comments in ejs %>

  <% if (gender =="male") { %>
    <h1>This is a female</h1>
  <% } else { %>
    <h1>This is a male</h1>

  <% } %>


  <%# for, each %>

  


  <div class="d-flex gap-3 flex-wrap">
    <% products.forEach((product, index) => { %>
      <div class="card" style="width: 18rem;">
        <div class="card-body">
          <h5 class="card-title"><%= product.title %></h5>
          <h6 class="card-subtitle mb-2 text-body-secondary">$ <%= product.price %></h6>
          <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card’s content.</p>
          <form action="/editProduct/<%= index %>" method="get"><button class="btn btn-primary">Edit</button></form>
          <form action="/delete/<%= index %>" method="post"><button class="btn btn-danger">Delete</button></form>
        </div>
      </div>
    <% }) %>



      <br>
    </div>
    <a href="/addProduct">Add more products</a>




  <script>

    
  </script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>